# Public (safe for the browser bundle)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Instagram mini feed — Behold (connected at behold.so)
NEXT_PUBLIC_INSTAGRAM_BEHOLD_ID=mkYtAUaIQdGISC7sBFy5

# Optional: LightWidget instead (if Behold is unset)
# NEXT_PUBLIC_INSTAGRAM_WIDGET_SRC=https://cdn.lightwidget.com/widgets/YOUR_WIDGET_ID.html

# Supabase — from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key

# Recommended for booking form (server-only — never expose in the browser)
# Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Optional: Google Places autocomplete for admin event locations
# Enable Maps JavaScript API + Places API in Google Cloud Console
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

ADMIN_EMAILS=info@ajeventspromotions.com,test-admin@ludzy.online,events-admin@ludzy.online
# Optional legacy fallback (not required if using server-side allowlist API)
# NEXT_PUBLIC_ADMIN_EMAILS=info@ajeventspromotions.com,test-admin@ludzy.online,events-admin@ludzy.online
