{
  "name": "ludzy-dj",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "tsc --noEmit && next build",
    "build:next": "next build",
    "typecheck": "node scripts/typecheck.mjs",
    "start": "next start",
    "lint": "next lint",
    "create-admin": "node --env-file=.env.local scripts/create-admin-user.mjs",
